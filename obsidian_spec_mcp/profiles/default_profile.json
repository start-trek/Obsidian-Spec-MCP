{
  "name": "default",
  "use_wikilinks": true,
  "prefer_properties": true,
  "default_packs": ["core", "tasks", "mermaid", "styling"],
  "tasks_global_filter": "#task",
  "tasks_custom_statuses": [],
  "linter_expectations": {
    "single_h1": true,
    "collapse_extra_blank_lines": true,
    "prefer_yaml_frontmatter": true
  },
  "mermaid_allowed_diagrams": [
    "flowchart",
    "graph",
    "sequenceDiagram",
    "classDiagram",
    "stateDiagram",
    "stateDiagram-v2",
    "erDiagram",
    "journey",
    "gantt",
    "pie",
    "gitGraph",
    "mindmap",
    "timeline",
    "quadrantChart",
    "requirementDiagram",
    "C4Context",
    "C4Container",
    "C4Component",
    "C4Dynamic",
    "C4Deployment"
  ],
  "mermaid_strict_parse": false,
  "mermaid_allow_wikilinks_in_labels": true
}
